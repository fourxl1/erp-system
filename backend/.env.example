# Server Port
PORT=5000

# Environment (development, production)
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Ruthgyamfua123.
DB_NAME=erp_system
# SSL mode for production database connections (disable, require, no-verify)
